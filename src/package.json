{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "chromatic": "npx chromatic",
    "typecheck": "nuxt prepare && vue-tsc --build",
    "analyze": "npx nuxi analyze",
    "project-info": "npx nuxi info",
    "verify:quick": "yarn format:check && yarn lint && yarn typecheck && yarn test:unit",
    "verify": "yarn verify:quick && yarn build && yarn storybook:build",
    "postinstall": "nuxt prepare",
    "prepare": "husky"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@nuxt/test-utils": "^4.0.3",
    "@pinia/testing": "^1.0.3",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/addon-vitest": "10.3.6",
    "@storybook/vue3-vite": "10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/compiler-dom": "^3.5.33",
    "@vue/test-utils": "^2.4.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "storybook": "10.3.6",
    "tailwindcss": "^4.2.4",
    "typescript": "6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^7.3.2",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "engines": {
    "node": "24.14.0"
  },
  "engineStrict": true,
  "packageManager": "yarn@4.13.0"
}
